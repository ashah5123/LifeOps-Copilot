{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "SparkUp Frontend (Next.js)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["next", "dev", "--port", "3000"],
      "port": 3000,
      "autoPort": false,
      "cwd": "frontend"
    },
    {
      "name": "SparkUp Backend (FastAPI)",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "uvicorn", "app.main:app", "--reload", "--port", "8000"],
      "port": 8000,
      "autoPort": false,
      "cwd": "backend"
    }
  ]
}
