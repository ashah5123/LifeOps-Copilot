# ============================================================
# SparkUp Backend — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# The app works without GCP credentials (uses keyword-based
# fallback agents), but enabling Vertex AI gives real Gemini-
# powered agent intelligence.
# ============================================================

# --- GCP Core ---
# Set your real GCP project ID to enable Vertex AI / Gemini.
# Leave as "sparkup-dev" to use mock/fallback mode.
GOOGLE_CLOUD_PROJECT=sparkup-dev
VERTEX_LOCATION=us-central1
VERTEX_MODEL_NAME=gemini-2.5-flash

# --- Firestore ---
# Same as GOOGLE_CLOUD_PROJECT, or a separate project.
FIRESTORE_PROJECT_ID=sparkup-dev

# --- Cloud Storage ---
GCS_BUCKET_NAME=sparkup-uploads

# --- Document AI (optional) ---
# Create a Document AI processor in GCP Console → Document AI
# to enable PDF/receipt text extraction via Google's OCR.
# Without this, PyPDF2 + Tesseract are used as local fallback.
DOCUMENT_AI_PROCESSOR_ID=

# --- Google OAuth (for Gmail integration) ---
# Get from GCP Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# Required for "Connect Gmail" feature. App works without it.
GOOGLE_CLIENT_ID=demo-client-id
GOOGLE_CLIENT_SECRET=demo-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# ============================================================
# HOW TO ACTIVATE VERTEX AI (Gemini) FOR REAL AGENT INTELLIGENCE
# ============================================================
# 1. Create a GCP project (or use existing one)
# 2. Enable the Vertex AI API:
#    gcloud services enable aiplatform.googleapis.com
# 3. Authenticate:
#    gcloud auth application-default login
# 4. Set GOOGLE_CLOUD_PROJECT to your real project ID above
# 5. Restart the backend server
#
# The agents will automatically switch from keyword fallback
# to Gemini-powered intelligence when Vertex AI is available.
# ============================================================

# RapidAPI — JSearch (https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch)
RAPIDAPI_KEY=your-rapidapi-key-here
RAPIDAPI_HOST=jsearch.p.rapidapi.com

# --- MongoDB (optional — durable storage for apps, users, OAuth tokens) ---
# When empty, the API uses an in-memory store (data lost on restart).
# Example: mongodb://localhost:27017
MONGODB_URI=
MONGODB_DATABASE=sparkup

# --- JWT (email/password auth) ---
# Use a long random secret in production, e.g. openssl rand -hex 32
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32
JWT_EXPIRE_MINUTES=10080

# --- Frontend (OAuth redirect after Gmail connect) ---
FRONTEND_URL=http://localhost:3000
